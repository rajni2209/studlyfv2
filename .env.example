# ⚠️ COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# NEVER commit the actual .env file to version control

# MongoDB
MONGO_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net
DB_NAME=studlyf

# JWT
JWT_SECRET=<your-secret-key-min-32-chars>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Super Admin
SUPER_ADMIN_EMAILS=admin@example.com

# SMTP Email
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your@email.com
EMAIL_FROM_NAME=Studlyf
SMART_EMAIL_PROVIDER=smtp
VERIFIED_DOMAIN_EMAIL=your@email.com

# Frontend
FRONTEND_URL=https://studlyf.in
RENDER_EXTERNAL_URL=https://api.studlyf.in
ADDITIONAL_CORS_ORIGINS=

# Firebase (optional - for push notifications)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
FIREBASE_SERVICE_ACCOUNT_JSON={}

# EmailJS (optional - for client-side emails)
VITE_EMAIL_JS_SERVICE_ID=
VITE_EMAIL_JS_TEMPLATE_ID=
VITE_EMAIL_JS_USER_ID=

# Payments (Razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Groq AI (optional - for AI features)
GROQ_API_KEY=
GROQ_API_KEY_CAREER=

# Sentry (optional - error tracking)
SENTRY_DSN=

# Redis (optional - for rate limiting)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Environment
ENVIRONMENT=development
VITE_SUPPORT_EMAIL=support@studlyf.com
